# =========================================================
# ApexDeploy - Environment Configuration
# Copy this file to .env and fill in your values
# =========================================================

# --- Google AI / Gemini ---
GOOGLE_API_KEY=AQ.Ab8RN6IvGsXIN39jJ9Mcve6Bj6DVZ6iY6VS2Ph9t12VXwaXkDw

# --- Application ---
APP_NAME=ApexDeploy
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0

# --- FastAPI Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# --- Streamlit Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501

# --- Database ---
DATABASE_URL=sqlite:///./data/apexdeploy.db
DATABASE_ECHO=false

# --- Docker ---
DOCKER_SOCKET=unix:///var/run/docker.sock
DOCKER_TIMEOUT=120
DOCKER_REGISTRY=
DOCKER_NETWORK=apexdeploy-network

# --- Git ---
GIT_CLONE_DEPTH=1
GIT_TIMEOUT=60
GITHUB_TOKEN=

# --- Workspaces ---
WORKSPACES_DIR=./workspaces
ARTIFACTS_DIR=./artifacts

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FORMAT=json
LOG_MAX_SIZE_MB=50
LOG_BACKUP_COUNT=5

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:8501,http://localhost:8000

# --- Monitoring ---
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
UNHEALTHY_THRESHOLD=3

# --- Pipeline ---
PIPELINE_TIMEOUT=600
MAX_CONCURRENT_PIPELINES=3
PIPELINE_RETRY_COUNT=2

# --- Telemetry ---
TELEMETRY_ENABLED=true
METRICS_RETENTION_DAYS=30
