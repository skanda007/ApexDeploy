# =============================================================
# ApexDeploy — Environment Configuration Template
# Autonomous Git-to-Cloud Resilience Engineer
# =============================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows CMD)
# =============================================================


# -------------------------------------------------------------
# 🔑 REQUIRED — Google Gemini / ADK
# Get your key at: https://aistudio.google.com/app/apikey
# This is the ONLY key you MUST set for the app to work.
# -------------------------------------------------------------
GOOGLE_API_KEY=AQ.Ab8RN6Kc47-_L5H9XyrshKXwGsIt-BxdbQECswRILgmSf0H82g
# -------------------------------------------------------------
# 🐙 OPTIONAL — GitHub Personal Access Token
# Needed only for private repositories or to avoid rate limits.
# Generate at: https://github.com/settings/tokens
# -------------------------------------------------------------
GITHUB_TOKEN=


# -------------------------------------------------------------
# 🛡️ Security
# Change SECRET_KEY to any long random string in production.
# -------------------------------------------------------------
SECRET_KEY=change-this-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:8501,http://localhost:8000


# -------------------------------------------------------------
# ⚡ FastAPI Server
# -------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1


# -------------------------------------------------------------
# 🖥️ Streamlit Dashboard
# -------------------------------------------------------------
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501
API_URL=http://localhost:8000


# -------------------------------------------------------------
# 🗃️ Database (SQLite — no extra setup needed)
# -------------------------------------------------------------
DATABASE_URL=sqlite:///./data/apexdeploy.db
DATABASE_ECHO=false


# -------------------------------------------------------------
# 🐳 Docker
# Windows Desktop: npipe:////./pipe/docker_engine
# Linux / Mac:     unix:///var/run/docker.sock
# -------------------------------------------------------------
DOCKER_SOCKET=npipe:////./pipe/docker_engine
DOCKER_TIMEOUT=120
DOCKER_REGISTRY=
DOCKER_NETWORK=apexdeploy-network


# -------------------------------------------------------------
# 📂 Git Cloning
# -------------------------------------------------------------
GIT_CLONE_DEPTH=1
GIT_TIMEOUT=60


# -------------------------------------------------------------
# 📁 Directories (relative to project root)
# -------------------------------------------------------------
WORKSPACES_DIR=./workspaces
ARTIFACTS_DIR=./artifacts


# -------------------------------------------------------------
# 📋 Logging
# LOG_FORMAT: json | text
# LOG_LEVEL:  DEBUG | INFO | WARNING | ERROR | CRITICAL
# -------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FORMAT=text
LOG_MAX_SIZE_MB=50
LOG_BACKUP_COUNT=5


# -------------------------------------------------------------
# 🚀 Pipeline Execution
# -------------------------------------------------------------
PIPELINE_TIMEOUT=600
MAX_CONCURRENT_PIPELINES=3
PIPELINE_RETRY_COUNT=2


# -------------------------------------------------------------
# 📊 Health Monitoring
# -------------------------------------------------------------
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
UNHEALTHY_THRESHOLD=3


# -------------------------------------------------------------
# 📈 Telemetry
# -------------------------------------------------------------
TELEMETRY_ENABLED=true
METRICS_RETENTION_DAYS=30


# -------------------------------------------------------------
# 🌍 Application
# APP_ENV: development | production
# -------------------------------------------------------------
APP_NAME=ApexDeploy
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
